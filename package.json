{
  "name": "cca-field-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:generate": "node scripts/generate-assets.mjs",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:no-analytics": "PUBLIC_GA_MEASUREMENT_ID= astro build && node scripts/check-no-analytics.mjs",
    "test:csp": "PUBLIC_GA_MEASUREMENT_ID=G-TEST123456 astro build && node scripts/check-csp-hashes.mjs",
    "test:e2e": "playwright test",
    "test:e2e:fast": "PW_REUSE_SERVER=1 playwright test --grep-invert @slow",
    "test:e2e:a11y": "playwright test accessibility.spec.ts",
    "test:e2e:reuse": "PW_REUSE_SERVER=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:production": "playwright test --config=playwright.production.config.ts",
    "test:watch": "vitest",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "test:bundle": "node scripts/check-initial-bundle.mjs",
    "test:styles": "node scripts/check-design-tokens.mjs",
    "verify:production": "node scripts/verify-production-deployment.mjs"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "astro": "^7.1.1",
    "preact": "^10.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "subset-font": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.30.3"
}
