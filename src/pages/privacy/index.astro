---
import GoogleAnalytics from '../../components/GoogleAnalytics.astro';
import { parseGoogleAnalyticsId } from '../../lib/analytics';
import '../../styles/global.css';

const analyticsEnabled = Boolean(parseGoogleAnalyticsId(import.meta.env.PUBLIC_GA_MEASUREMENT_ID));
const title = 'プライバシー — CCA Field Notes';
const description = 'CCA Field Notesにおける学習データとアクセス解析の取り扱い';
const site = Astro.site ?? new URL('https://cca.toshi0607.com');
const canonicalUrl = new URL('/privacy/', site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#173447" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <title>{title}</title>
    <GoogleAnalytics />
  </head>
  <body class="privacy-page">
    <a class="skip-link" href="#main-content">本文へ移動</a>
    <header class="privacy-header">
      <a class="wordmark" href="/" aria-label="CCA Field Notes トップへ"><b>CCA</b><span>FIELD NOTES</span></a>
      <a href="/">学習ノートへ戻る →</a>
    </header>
    <main id="main-content" class="privacy-main">
      <article class="privacy-article">
        <p class="eyebrow">PRIVACY / ANALYTICS</p>
        <h1>プライバシー</h1>
        <p class="lead">このページでは、学習進捗とサイト利用状況の取り扱いを説明します。</p>

        <section aria-labelledby="study-data-title">
          <h2 id="study-data-title">学習データ</h2>
          <p>カードの評価、復習予定、検索語などの学習データは、このブラウザのlocalStorageだけに保存します。サーバーへの同期やアカウントとの紐付けは行いません。</p>
        </section>

        {analyticsEnabled && <section aria-labelledby="analytics-title">
          <h2 id="analytics-title">アクセス解析</h2>
          <p>サイト改善のためGoogle Analytics 4を使用し、閲覧ページ、アクセス日時、ブラウザ・端末種別、おおよその地域などの基本的な利用状況を収集します。</p>
          <ul>
            <li>学習カードの内容、アプリ内検索語、評価、進捗データを独自イベントとして送信しません。</li>
            <li>広告ストレージ、広告向けユーザーデータ、広告パーソナライズを無効にしています。</li>
            <li>Google Signalsと広告パーソナライズ用シグナルを無効にしています。</li>
          </ul>
          <p>Googleによるデータの取り扱いは、<a href="https://policies.google.com/technologies/partner-sites?hl=ja" target="_blank" rel="noreferrer">Googleサービスを使用するサイトやアプリから収集した情報の利用方法<span class="sr-only">（新しいタブで開く）</span> ↗</a>をご確認ください。</p>
        </section>}

        {analyticsEnabled && <section aria-labelledby="cookies-title">
          <h2 id="cookies-title">Cookieと無効化</h2>
          <p>Google Analyticsは訪問を区別するためにCookieを使用します。ブラウザの設定でCookieを削除・制限できるほか、<a href="https://tools.google.com/dlpage/gaoptout?hl=ja" target="_blank" rel="noreferrer">Google Analyticsオプトアウト アドオン<span class="sr-only">（新しいタブで開く）</span> ↗</a>も利用できます。</p>
        </section>}

        <section aria-labelledby="contact-title">
          <h2 id="contact-title">お問い合わせ</h2>
          <p>記載内容への質問や修正依頼は、<a href="https://github.com/toshi0607/cca-study-guide/issues" target="_blank" rel="noreferrer">GitHub Issues<span class="sr-only">（新しいタブで開く）</span> ↗</a>へお寄せください。</p>
        </section>

        <p class="privacy-updated">最終更新: 2026-07-15</p>
      </article>
    </main>
  </body>
</html>
