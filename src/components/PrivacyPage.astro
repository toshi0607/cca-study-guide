---
import { localePaths, locales, type Locale } from '../i18n/locales';
import { siteCopy } from '../i18n/site';

interface Props {
  locale: Locale;
  analyticsEnabled: boolean;
}

const { locale, analyticsEnabled } = Astro.props;
const copy = siteCopy[locale];
const privacy = copy.privacy;
---

<header class="privacy-header">
  <a class="wordmark" href={localePaths[locale].app} aria-label={copy.homeAriaLabel}><b>CCA</b><span>FIELD NOTES</span></a>
  <nav class="language-switcher language-switcher--privacy" aria-label={copy.languageNavigationLabel}>
    {locales.map((candidate) => (
      <a
        href={localePaths[candidate].privacy}
        lang={candidate}
        hreflang={candidate}
        aria-current={candidate === locale ? 'page' : undefined}
      >{candidate === 'ja' ? '日本語' : 'English'}</a>
    ))}
  </nav>
  <a href={localePaths[locale].app}>{copy.backToGuide}</a>
</header>
<main id="main-content" class="privacy-main">
  <article class="privacy-article panel">
    <p class="eyebrow">{privacy.eyebrow}</p>
    <h1 class="page-title">{privacy.heading}</h1>
    <p class="lead">{privacy.lead}</p>

    <section aria-labelledby="study-data-title">
      <h2 class="section-title" id="study-data-title">{privacy.studyDataHeading}</h2>
      <p>{privacy.studyData}</p>
    </section>

    {analyticsEnabled && <section aria-labelledby="analytics-title">
      <h2 class="section-title" id="analytics-title">{privacy.analyticsHeading}</h2>
      <p>{privacy.analyticsIntro}</p>
      <ul>
        {privacy.analyticsExclusions.map((item) => <li>{item}</li>)}
      </ul>
      <p>{privacy.googleDataPrefix}<a href={`https://policies.google.com/technologies/partner-sites?hl=${locale}`} target="_blank" rel="noreferrer">{privacy.googleDataLink}<span class="sr-only"> {privacy.newTab}</span> ↗</a></p>
    </section>}

    {analyticsEnabled && <section aria-labelledby="cookies-title">
      <h2 class="section-title" id="cookies-title">{privacy.cookiesHeading}</h2>
      <p>{privacy.cookiesPrefix}<a href={`https://tools.google.com/dlpage/gaoptout?hl=${locale}`} target="_blank" rel="noreferrer">{privacy.optOutLink}<span class="sr-only"> {privacy.newTab}</span> ↗</a>{privacy.cookiesSuffix}</p>
    </section>}

    <section aria-labelledby="contact-title">
      <h2 class="section-title" id="contact-title">{privacy.contactHeading}</h2>
      <p>{privacy.contactPrefix}<a href="https://github.com/toshi0607/cca-study-guide/issues" target="_blank" rel="noreferrer">GitHub Issues<span class="sr-only"> {privacy.newTab}</span> ↗</a>{privacy.contactSuffix}</p>
    </section>

    <p class="privacy-updated">{privacy.updated}</p>
  </article>
</main>
