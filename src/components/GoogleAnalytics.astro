---
import { parseGoogleAnalyticsId } from '../lib/analytics';

const measurementId = parseGoogleAnalyticsId(import.meta.env.PUBLIC_GA_MEASUREMENT_ID);
---

{measurementId && (
  <>
    <meta name="ga-measurement-id" content={measurementId} />
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script>
      interface GtagWindow extends Window {
        dataLayer?: unknown[];
        gtag?: (...args: unknown[]) => void;
      }
      const scope = window as GtagWindow;
      const id = document
        .querySelector('meta[name="ga-measurement-id"]')
        ?.getAttribute('content');
      if (id) {
        scope.dataLayer = scope.dataLayer || [];
        const gtag: (...args: unknown[]) => void =
          scope.gtag ||
          function () {
            scope.dataLayer!.push(arguments);
          };
        scope.gtag = gtag;
        gtag('consent', 'default', {
          analytics_storage: 'granted',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
        gtag('js', new Date());
        gtag('config', id, {
          allow_google_signals: false,
          allow_ad_personalization_signals: false,
          cookie_domain: 'none',
        });
      }
    </script>
  </>
)}
